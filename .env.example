# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — local dev (ignored when DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alwar_rojgar_setu
DB_USER=amritag
DB_PASSWORD=

# Production DB (Neon / any Postgres provider) — takes priority over individual DB_* vars
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Frontend URL for OAuth redirect
FRONTEND_URL=http://localhost:5173

# Admin invite code (required for admin self-registration)
ADMIN_INVITE_CODE=admin-secret-code-change-me

# Email / SMTP (for OTP verification emails)
# Option A — Gmail SMTP (dev/testing only, 500 emails/day limit)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
# Option B — Resend (recommended free alternative, 3000 emails/month)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# Production sender (once GoDaddy domain is set up)
EMAIL_FROM=Alwar Rojgar Setu <noreply@alwarrojgarsetu.in>

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# CORS — local dev; production = https://alwar-rojgar-setu-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173
