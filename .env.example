# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — local dev (ignored when DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alwar_rojgar_setu
DB_USER=postgres
DB_PASSWORD=postgres

# Production DB (Neon / any Postgres provider) — takes priority over individual DB_* vars
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# OTP (dev mode logs to console, production uses SMS provider)
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
SMS_PROVIDER=console

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# CORS — local dev; production = https://alwar-rojgar-setu-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173
