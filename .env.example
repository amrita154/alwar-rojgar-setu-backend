# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — local dev (ignored when DATABASE_URL is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alwar_rojgar_setu
DB_USER=amritag
DB_PASSWORD=

# Production DB (Neon / any Postgres provider) — takes priority over individual DB_* vars
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Frontend URL for OAuth redirect
FRONTEND_URL=http://localhost:5173

# Admin invite code (required for admin self-registration)
ADMIN_INVITE_CODE=admin-secret-code-change-me

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# CORS — local dev; production = https://alwar-rojgar-setu-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173
